components:
  schemas:
    Appointment:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        patient:
          allOf:
          - $ref: '#/components/schemas/User'
          readOnly: true
        doctor:
          type: integer
        doctor_details:
          allOf:
          - $ref: '#/components/schemas/Doctor'
          readOnly: true
        appointment_date:
          type: string
          format: date
        appointment_time:
          type: string
          format: time
        status:
          $ref: '#/components/schemas/Status9d8Enum'
        reason:
          type: string
        notes:
          type: string
        prescription:
          allOf:
          - $ref: '#/components/schemas/Prescription'
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - appointment_date
      - appointment_time
      - doctor
      - reason
    AppointmentCreateRequest:
      type: object
      properties:
        doctor:
          type: integer
          description: ID of the doctor to book appointment with (must be available)
        appointment_date:
          type: string
          format: date
          description: Appointment date in YYYY-MM-DD format
        appointment_time:
          type: string
          format: time
          description: Appointment time in HH:MM format (30-minute slots, e.g., 09:00,
            09:30)
        reason:
          type: string
          minLength: 1
          description: Reason for appointment or symptoms description
          maxLength: 500
      required:
      - appointment_date
      - appointment_time
      - doctor
      - reason
    AppointmentStatus:
      type: object
      properties:
        status:
          $ref: '#/components/schemas/Status9d8Enum'
        notes:
          type: string
    AppointmentStatusRequest:
      type: object
      properties:
        status:
          $ref: '#/components/schemas/Status9d8Enum'
        notes:
          type: string
    Doctor:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        user:
          allOf:
          - $ref: '#/components/schemas/User'
          readOnly: true
          description: User account information including name, email, and contact
            details
        specialization:
          type: string
          description: Medical specialization (e.g., Cardiology, Dermatology, Pediatrics)
        qualification:
          type: string
          description: Medical qualifications and degrees (e.g., MBBS, MD)
        experience_years:
          type: integer
          description: Years of medical practice experience
        consultation_fee:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Consultation fee amount in local currency
        bio:
          type: string
          description: Doctor biography and additional professional information
        is_available:
          type: boolean
          description: Whether the doctor is currently accepting appointments
        availability:
          type: array
          items:
            $ref: '#/components/schemas/DoctorAvailability'
          readOnly: true
          description: Weekly availability schedule for the doctor
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - bio
      - consultation_fee
      - experience_years
      - is_available
      - qualification
      - specialization
    DoctorAvailability:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        day_of_week:
          type: integer
          description: Day of week as integer (0=Monday, 1=Tuesday, ..., 6=Sunday)
        day_name:
          type: string
          readOnly: true
          description: Human-readable day name (e.g., Monday, Tuesday)
        start_time:
          type: string
          format: time
          description: Availability start time in HH:MM format (24-hour)
        end_time:
          type: string
          format: time
          description: Availability end time in HH:MM format (24-hour)
        is_active:
          type: boolean
          default: true
          description: Whether this availability slot is currently active
      required:
      - day_of_week
      - end_time
      - start_time
    DoctorAvailabilityRequest:
      type: object
      properties:
        day_of_week:
          type: integer
          description: Day of week as integer (0=Monday, 1=Tuesday, ..., 6=Sunday)
        start_time:
          type: string
          format: time
          description: Availability start time in HH:MM format (24-hour)
        end_time:
          type: string
          format: time
          description: Availability end time in HH:MM format (24-hour)
        is_active:
          type: boolean
          default: true
          description: Whether this availability slot is currently active
      required:
      - day_of_week
      - end_time
      - start_time
    FrequencyEnum:
      enum:
      - once
      - twice
      - thrice
      - as_needed
      type: string
      description: |-
        * `once` - Once daily
        * `twice` - Twice daily
        * `thrice` - Thrice daily
        * `as_needed` - As needed
    Medicine:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          description: Name of the medicine or drug
          maxLength: 200
        dosage:
          type: string
          description: Dosage amount and unit (e.g., 500mg, 10ml)
          maxLength: 100
        frequency:
          allOf:
          - $ref: '#/components/schemas/FrequencyEnum'
          description: |-
            Frequency of medication intake: once, twice, thrice, or as_needed

            * `once` - Once daily
            * `twice` - Twice daily
            * `thrice` - Thrice daily
            * `as_needed` - As needed
        frequency_display:
          type: string
          readOnly: true
        duration_days:
          type: integer
          description: Duration of medication in days
        timing_notes:
          type: string
          description: Additional timing instructions (e.g., after meals, before bed)
      required:
      - dosage
      - duration_days
      - frequency
      - name
    MedicineRequest:
      type: object
      properties:
        name:
          type: string
          minLength: 1
          description: Name of the medicine or drug
          maxLength: 200
        dosage:
          type: string
          minLength: 1
          description: Dosage amount and unit (e.g., 500mg, 10ml)
          maxLength: 100
        frequency:
          allOf:
          - $ref: '#/components/schemas/FrequencyEnum'
          description: |-
            Frequency of medication intake: once, twice, thrice, or as_needed

            * `once` - Once daily
            * `twice` - Twice daily
            * `thrice` - Thrice daily
            * `as_needed` - As needed
        duration_days:
          type: integer
          description: Duration of medication in days
        timing_notes:
          type: string
          description: Additional timing instructions (e.g., after meals, before bed)
      required:
      - dosage
      - duration_days
      - frequency
      - name
    Notification:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        user:
          type: integer
          readOnly: true
          description: ID of the user who receives this notification
        title:
          type: string
          description: Notification title or subject
          maxLength: 200
        message:
          type: string
          description: Notification message content
        is_read:
          type: boolean
          default: false
          description: Whether the notification has been read by the user
        created_at:
          type: string
          format: date-time
          readOnly: true
          description: Timestamp when the notification was created
      required:
      - message
      - title
    PaginatedAppointmentList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Appointment'
    PaginatedDoctorList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Doctor'
    PaginatedNotificationList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Notification'
    PaginatedPaymentList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Payment'
    PaginatedReviewList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/Review'
    PaginatedUserList:
      type: object
      required:
      - count
      - results
      properties:
        count:
          type: integer
          example: 123
        next:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=4
        previous:
          type: string
          nullable: true
          format: uri
          example: http://api.example.org/accounts/?page=2
        results:
          type: array
          items:
            $ref: '#/components/schemas/User'
    PatchedAppointmentStatusRequest:
      type: object
      properties:
        status:
          $ref: '#/components/schemas/Status9d8Enum'
        notes:
          type: string
    PatchedDoctorAvailabilityRequest:
      type: object
      properties:
        day_of_week:
          type: integer
          description: Day of week as integer (0=Monday, 1=Tuesday, ..., 6=Sunday)
        start_time:
          type: string
          format: time
          description: Availability start time in HH:MM format (24-hour)
        end_time:
          type: string
          format: time
          description: Availability end time in HH:MM format (24-hour)
        is_active:
          type: boolean
          default: true
          description: Whether this availability slot is currently active
    PatchedDoctorProfileUpdateRequest:
      type: object
      description: Allows doctor to update their own profile fields.
      properties:
        consultation_fee:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
        bio:
          type: string
        is_available:
          type: boolean
        specialization:
          type: string
          minLength: 1
          maxLength: 100
        qualification:
          type: string
          minLength: 1
          maxLength: 200
        experience_years:
          type: integer
          maximum: 2147483647
          minimum: -2147483648
    PatchedUserRequest:
      type: object
      properties:
        username:
          type: string
          minLength: 1
          description: Required. 150 characters or fewer. Letters, digits and @/./+/-/_
            only.
          pattern: ^[\w.@+-]+$
          maxLength: 150
        email:
          type: string
          format: email
          title: Email address
          maxLength: 254
        first_name:
          type: string
          maxLength: 150
        last_name:
          type: string
          maxLength: 150
        role:
          $ref: '#/components/schemas/UserRoleEnum'
        phone:
          type: string
          maxLength: 15
        date_of_birth:
          type: string
          format: date
          nullable: true
        address:
          type: string
        profile_picture:
          type: string
          format: binary
          nullable: true
    Payment:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        appointment:
          type: integer
          readOnly: true
          description: ID of the associated appointment
        amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          description: Payment amount in local currency
        status:
          allOf:
          - $ref: '#/components/schemas/PaymentStatusEnum'
          description: |-
            Payment status: pending, completed, failed, or refunded

            * `pending` - Pending
            * `completed` - Completed
            * `failed` - Failed
            * `refunded` - Refunded
        payment_method:
          type: string
          description: Payment method used (e.g., credit_card, debit_card, cash, insurance)
          maxLength: 50
        transaction_id:
          type: string
          nullable: true
          description: Unique transaction identifier from payment gateway
          maxLength: 100
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - amount
      - payment_method
      - status
    PaymentStatusEnum:
      enum:
      - pending
      - completed
      - failed
      - refunded
      type: string
      description: |-
        * `pending` - Pending
        * `completed` - Completed
        * `failed` - Failed
        * `refunded` - Refunded
    Prescription:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        appointment:
          type: integer
          readOnly: true
        diagnosis:
          type: string
        instructions:
          type: string
        medicines:
          type: array
          items:
            $ref: '#/components/schemas/Medicine'
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - diagnosis
    PrescriptionCreateRequest:
      type: object
      properties:
        diagnosis:
          type: string
          minLength: 1
          description: Medical diagnosis or condition identified by the doctor
          maxLength: 500
        instructions:
          type: string
          description: Additional instructions for the patient (e.g., dietary advice,
            precautions)
        medicines:
          type: array
          items:
            $ref: '#/components/schemas/MedicineRequest'
      required:
      - diagnosis
      - medicines
    RegisterRequest:
      type: object
      properties:
        username:
          type: string
          minLength: 1
          description: Required. 150 characters or fewer. Letters, digits and @/./+/-/_
            only.
          pattern: ^[\w.@+-]+$
          maxLength: 150
        email:
          type: string
          format: email
          title: Email address
          maxLength: 254
        password:
          type: string
          writeOnly: true
          minLength: 1
          description: Password must be at least 8 characters with letters and numbers
        password2:
          type: string
          writeOnly: true
          minLength: 1
          description: Confirm password (must match password field)
        first_name:
          type: string
          maxLength: 150
        last_name:
          type: string
          maxLength: 150
        role:
          allOf:
          - $ref: '#/components/schemas/RegisterRoleEnum'
          default: patient
          description: |-
            User role: patient, doctor, or admin

            * `patient` - patient
            * `doctor` - doctor
            * `admin` - admin
        phone:
          type: string
          description: Contact phone number with country code
      required:
      - password
      - password2
      - username
    RegisterRoleEnum:
      enum:
      - patient
      - doctor
      - admin
      type: string
      description: |-
        * `patient` - patient
        * `doctor` - doctor
        * `admin` - admin
    Review:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        patient:
          allOf:
          - $ref: '#/components/schemas/User'
          readOnly: true
          description: Patient who wrote the review
        doctor:
          type: integer
          description: ID of the doctor being reviewed
        rating:
          type: integer
          maximum: 5
          minimum: 1
          description: Rating from 1 to 5 stars (1=poor, 5=excellent)
        comment:
          type: string
          description: Review comment describing the experience with the doctor
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - comment
      - doctor
      - rating
    ReviewRequest:
      type: object
      properties:
        doctor:
          type: integer
          description: ID of the doctor being reviewed
        rating:
          type: integer
          maximum: 5
          minimum: 1
          description: Rating from 1 to 5 stars (1=poor, 5=excellent)
        comment:
          type: string
          minLength: 1
          description: Review comment describing the experience with the doctor
      required:
      - comment
      - doctor
      - rating
    Status9d8Enum:
      enum:
      - pending
      - confirmed
      - completed
      - cancelled
      type: string
      description: |-
        * `pending` - Pending
        * `confirmed` - Confirmed
        * `completed` - Completed
        * `cancelled` - Cancelled
    TokenObtainPair:
      type: object
      properties:
        access:
          type: string
          readOnly: true
        refresh:
          type: string
          readOnly: true
    TokenObtainPairRequest:
      type: object
      properties:
        username:
          type: string
          writeOnly: true
          minLength: 1
        password:
          type: string
          writeOnly: true
          minLength: 1
      required:
      - password
      - username
    TokenRefresh:
      type: object
      properties:
        access:
          type: string
          readOnly: true
        refresh:
          type: string
      required:
      - refresh
    TokenRefreshRequest:
      type: object
      properties:
        refresh:
          type: string
          minLength: 1
      required:
      - refresh
    User:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        username:
          type: string
          description: Required. 150 characters or fewer. Letters, digits and @/./+/-/_
            only.
          pattern: ^[\w.@+-]+$
          maxLength: 150
        email:
          type: string
          format: email
          title: Email address
          maxLength: 254
        first_name:
          type: string
          maxLength: 150
        last_name:
          type: string
          maxLength: 150
        role:
          $ref: '#/components/schemas/UserRoleEnum'
        phone:
          type: string
          maxLength: 15
        date_of_birth:
          type: string
          format: date
          nullable: true
        address:
          type: string
        profile_picture:
          type: string
          format: uri
          nullable: true
      required:
      - username
    UserRequest:
      type: object
      properties:
        username:
          type: string
          minLength: 1
          description: Required. 150 characters or fewer. Letters, digits and @/./+/-/_
            only.
          pattern: ^[\w.@+-]+$
          maxLength: 150
        email:
          type: string
          format: email
          title: Email address
          maxLength: 254
        first_name:
          type: string
          maxLength: 150
        last_name:
          type: string
          maxLength: 150
        role:
          $ref: '#/components/schemas/UserRoleEnum'
        phone:
          type: string
          maxLength: 15
        date_of_birth:
          type: string
          format: date
          nullable: true
        address:
          type: string
        profile_picture:
          type: string
          format: binary
          nullable: true
      required:
      - username
    UserRoleEnum:
      enum:
      - patient
      - doctor
      - admin
      type: string
      description: |-
        * `patient` - Patient
        * `doctor` - Doctor
        * `admin` - Admin
  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
      description: 'JWT token obtained from /api/auth/login/ endpoint. Format: Bearer
        {token}'
    jwtAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
